# Groq API Configuration (Required - all agents and workflows execute on Groq)
GROQ_API_KEY="your-groq-api-key"

# Optional: Specify a custom Groq model name (defaults to groq/llama-3.3-70b-versatile)
# MODEL_NAME="groq/llama-3.3-70b-versatile"

# Gemini API Configuration (Required for the AI Mentor Chat feature)
GEMINI_API_KEY="your-gemini-api-key"
# Optional: Specify a custom Gemini model name (defaults to google/gemini-2.5-flash)
# CHAT_MODEL_NAME="google/gemini-2.5-flash"
